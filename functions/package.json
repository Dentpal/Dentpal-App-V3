{
  "name": "dentpal-functions",
  "version": "1.0.0",
  "description": "Firebase Functions for DentPal App",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "axios": "^1.4.0",
    "cors": "^2.8.5",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^6.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.19",
    "typescript": "^4.9.0"
  },
  "private": true
}
